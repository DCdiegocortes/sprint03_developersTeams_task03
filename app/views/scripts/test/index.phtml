                        <h3><?= htmlspecialchars($task['title'] ?? 'Sin título', ENT_QUOTES, 'UTF-8') ?></h3>

                        <small>
                            Creado por: <?= htmlspecialchars($task['user_name'] ?? 'Anónimo', ENT_QUOTES, 'UTF-8') ?>
                        </small>

                        <div class="quick-actions">
                            <a href="/task/finish?id=<?= $taskId ?>" class="icon-btn">

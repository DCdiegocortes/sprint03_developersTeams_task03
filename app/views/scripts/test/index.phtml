                            </a>

                            <a href="/task/edit?id=<?= $taskId ?>" class="more-btn" title="Editar tarea">
                                ⋯
                            </a>
                        </div>
                    </article>
                <?php endif; ?>
            <?php endforeach; ?>

            <?php if (!$hasProgressTasks): ?>
                <p class="empty-state">No hay tareas en ejecución.</p>
            <?php endif; ?>
        </div>

        <div class="task-column">
            <h2>Terminadas</h2>

            <?php $hasFinishedTasks = false; ?>


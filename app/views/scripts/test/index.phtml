$tasks = $this->tasks;

if (!is_array($tasks)) {
    $tasks = [];
}
?>

<div class="dashboard-page">
    <section class="dashboard-header">
        <h1>¿Qué quieres hacer hoy?</h1>
        <p>Organiza tus tareas, revisa su estado y mantén el control del trabajo pendiente.</p>
    </section>

    <?php if (!empty($this->update_message)): ?>
        <p class="message success">Tarea actualizada correctamente.</p>
    <?php endif; ?>

    <?php if (!empty($this->update_error)): ?>
        <p class="message error">No se pudo actualizar la tarea. Revisá los datos ingresados.</p>
    <?php endif; ?>

    <section class="tasks-board">
        <div class="task-column">
            <h2>Pendientes</h2>

            <?php $hasPendingTasks = false; ?>

            <?php foreach ($tasks as $task): ?>
                <?php if (($task['status'] ?? '') === 'PENDING'): ?>
                    <?php
                    $hasPendingTasks = true;
                    $taskId = urlencode((string) ($task['id'] ?? ''));
                    ?>

                    <article class="task-card">
                        <h3><?= htmlspecialchars($task['title'] ?? 'Sin título', ENT_QUOTES, 'UTF-8') ?></h3>

                        <small>
                            Creado por: <?= htmlspecialchars($task['user_name'] ?? 'Anónimo', ENT_QUOTES, 'UTF-8') ?>
                        </small>

                        <div class="quick-actions">
                            <a href="/task/play?id=<?= $taskId ?>" class="icon-btn">
                                ▶️ Play
                            </a>

                            <a href="/task/edit?id=<?= $taskId ?>" class="more-btn" title="Editar tarea">
                                ⋯
                            </a>
                        </div>
                    </article>
                <?php endif; ?>
            <?php endforeach; ?>

            <?php if (!$hasPendingTasks): ?>
                <p class="empty-state">No hay tareas pendientes.</p>
            <?php endif; ?>
        </div>

        <div class="task-column">
            <h2>En ejecución</h2>

            <?php $hasProgressTasks = false; ?>

